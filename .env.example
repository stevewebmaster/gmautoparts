APP_NAME="G&M Autospares"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Use SQLite for local dev without MySQL (create file: touch database/database.sqlite):
# DB_CONNECTION=sqlite
# # DB_DATABASE is optional; defaults to database/database.sqlite
#
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gm_autospares
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@gmautospares.co.nz"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@gmautospares.co.nz

# Mini-app: PIN to add parts/vehicles from phone (e.g. /app). Leave empty to disable.
MINIAPP_PIN=
