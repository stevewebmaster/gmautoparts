# Copy this to your server as .env and fill in the placeholders.
# On server: cp .env.sitehost.example .env  then  nano .env
# See docs/DEPLOY-SITEHOST.md for full deploy notes.

APP_NAME="G&M Autospares"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Use https and no trailing slash so assets/forms work over HTTPS behind proxy
APP_URL=https://gm.websitemaster.co.nz

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
# SiteHost Cloud Containers: use DB host they provide (e.g. mariadb1011), not localhost
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gmauto3
DB_USERNAME=gmautowebmnz3
DB_PASSWORD=2vxbCyMTwGRg9ZJ6YpQeeTawdtBmuQpFZy97nTW

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mail.yourdomain.co.nz
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.co.nz
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.co.nz"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@yourdomain.co.nz

# Mini-app at /app — PIN required; leave empty to disable mini-app routes
MINIAPP_PIN=

# Set to false if uploads fail (missing GD/Imagick or image processing errors on host)
MINIAPP_OPTIMIZE_UPLOADS=true
