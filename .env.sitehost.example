# Copy this to your server as .env and fill in the placeholders.
# On server: cp .env.sitehost.example .env  then  nano .env

APP_NAME="G&M Autospares"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.co.nz

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_sitehost_db_name
DB_USERNAME=your_sitehost_db_user
DB_PASSWORD=your_sitehost_db_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mail.yourdomain.co.nz
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.co.nz
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.co.nz"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@yourdomain.co.nz
